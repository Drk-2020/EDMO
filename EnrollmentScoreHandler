public class EnrollmentScoreHandler {

    public static void updateContactPriority(List<Enrollment_Score__c> scores) {

        Map<Id, Enrollment_Score__c> latestScoreMap = new Map<Id, Enrollment_Score__c>();

        for (Enrollment_Score__c esc : scores) {
            if (!latestScoreMap.containsKey(esc.Contact__c) ||
                esc.Scored_At__c > latestScoreMap.get(esc.Contact__c).Scored_At__c) {

                latestScoreMap.put(esc.Contact__c, esc);
            }
        }

        List<Contact> contactsToUpdate = new List<Contact>();

        for (Id conId : latestScoreMap.keySet()) {
            Enrollment_Score__c esc = latestScoreMap.get(conId);

            String priority;

            if (esc.Score__c >= 75) priority = 'Hot';
            else if (esc.Score__c >= 40) priority = 'Warm';
            else priority = 'Cold';

            contactsToUpdate.add(new Contact(
                Id = conId,
                Enrollment_Priority__c = priority
            ));
        }

        if (!contactsToUpdate.isEmpty()) {

            TriggerControl.bypassContactTrigger = true;

            update contactsToUpdate;

            TriggerControl.bypassContactTrigger = false;
        }
    }
}
